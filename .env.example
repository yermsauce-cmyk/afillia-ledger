# Copy to .env and fill in. Never commit .env.
# Everything is OPTIONAL — the agent runs fully offline with Ollama.

# --- Local LLM (already running if you have Ollama installed) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3-coder:latest

# --- Free cloud LLM fallbacks (only set if you want them) ---
# Groq free tier: https://console.groq.com (no credit card)
# GROQ_API_KEY=
# Anthropic free tier: https://console.anthropic.com
# ANTHROPIC_API_KEY=

# --- Email alerts (Gmail App Password recommended, free) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your-16-char-app-password
# ALERT_TO=your.email@gmail.com

# --- Webhook alerts (Slack/Discord incoming webhook, free) ---
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Reddit (optional, public RSS works without auth) ---
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
